# Service Configuration
SERVICE_PORT=8002
SERVICE_NAME=core

# Django Settings
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,core

# Database (Shared across all services)
DB_HOST=db
DB_PORT=5432
DB_NAME=spotifydb
DB_USER=spotifyuser
DB_PASSWORD=spotifypass

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://auth:8001
COLLAB_SERVICE_URL=http://collaboration:8003
PLAYBACK_SERVICE_URL=http://playback:8004
