# Service Configuration
SERVICE_PORT=8004
SERVICE_NAME=playback

# Django Settings
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,playback

